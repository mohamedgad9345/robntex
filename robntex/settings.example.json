{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Recommended permissions for RobNTex. Copy the `permissions` block into your project's .claude/settings.json (merge with anything already there). Plugin manifests can't ship permission rules, so this must be done per project.",
  "permissions": {
    "allow": [
      "Bash(npx playwright-cli --version)",
      "Bash(npx playwright-cli --help)",
      "Bash(npx playwright-cli install-browser chromium)",
      "Bash(npx playwright-cli open *)",
      "Bash(npx playwright-cli -s=* open *)",
      "Bash(npx playwright-cli snapshot)",
      "Bash(npx playwright-cli -s=* snapshot)",
      "Bash(npx playwright-cli screenshot *)",
      "Bash(npx playwright-cli -s=* screenshot *)",
      "Bash(npx playwright-cli console *)",
      "Bash(npx playwright-cli -s=* console *)",
      "Bash(npx playwright-cli click *)",
      "Bash(npx playwright-cli -s=* click *)",
      "Bash(npx playwright-cli type *)",
      "Bash(npx playwright-cli -s=* type *)",
      "Bash(npx playwright-cli select *)",
      "Bash(npx playwright-cli -s=* select *)",
      "Bash(npx playwright-cli wait *)",
      "Bash(npx playwright-cli -s=* wait *)",
      "Bash(npx playwright-cli eval *)",
      "Bash(npx playwright-cli -s=* eval *)",
      "Bash(npx playwright-cli run-code *)",
      "Bash(npx playwright-cli -s=* run-code *)",
      "Bash(npx playwright-cli close)",
      "Bash(npx playwright-cli -s=* close)",
      "Bash(npm install -D @playwright/cli)",
      "Bash(python3 -c \"import openpyxl*)",
      "Bash(pip install openpyxl*)",
      "Bash(mkdir -p executions/*)",
      "Bash(mkdir -p testcases/*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/*credentials*)",
      "Read(**/*secret*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Bash(rm -rf *)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Write(src/**)",
      "Write(app/**)",
      "Write(server/**)",
      "Edit(src/**)",
      "Edit(app/**)",
      "Edit(server/**)"
    ]
  }
}
