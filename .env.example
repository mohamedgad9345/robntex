# RobNTex — optional environment values
# Copy to .env in your project root and fill in what applies.
# NEVER commit .env — add it to .gitignore.

# --- Target environment -------------------------------------------------------
# Default ROBIN URL. If set, /execute-tc uses this when no URL is passed inline.
# Example: https://robin-uat.your-company.example
ROBIN_URL=https://auto-robin-qtr.santechture.com/ROBIN/faces/home.xhtml
ROBIN_ENV=Staging
ROBIN_USER=QFacilityAdmin
ROBIN_PASSWORD=QFacilityAdmin123

# Human label for reports (`UAT` / `Staging` / `Prod-like`). Falls into the
# `Environment` field of each Jira-ready bug block.
#ROBIN_ENV=UAT

# --- Jira (Level 2 — not used yet) --------------------------------------------
# These are placeholders for the future `jira-integration` skill (Level 2).
# In Level 1, RobNTex only emits Jira-ready markdown blocks — no API calls.
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_PROJECT_KEY=ROBIN
# JIRA_DEFAULT_ISSUE_TYPE=Bug
